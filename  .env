# 1. Dùng cho Client-side (Trình duyệt gọi API)
# Nếu không truyền, code sẽ mặc định lấy "http://localhost:8080/api"
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# 2. Dùng cho Server-side (Next.js gọi API lúc render SSR/SSG)
# Thường được dùng trong các hàm fetch ở file lookup.server.ts
INTERNAL_API_BASE_URL=http://localhost:8080/api

# 3. Môi trường chạy code (Mặc định Next.js tự set)
# Được dùng trong MSWProvider.tsx để bật/tắt mock API
NODE_ENV=development